@page "/skills"
@rendermode InteractiveServer

<PageTitle>Skills</PageTitle>

<div class="skills-container">
    <h1 class="skills-title">Skills and Technologies</h1>

    <div class="skills-grid">
        <SkillCard Title="Frontend" Items="@frontendSkills" />
        <SkillCard Title="Backend" Items="@backendSkills" />
        <SkillCard Title="Database" Items="@databaseSkills" />
    </div>
</div>

@code {
    private List<string> frontendSkills = new()
    {
        "Blazor",
        "HTML / CSS",
        "Bootstrap"
    };

    private List<string> backendSkills = new()
    {
        "C#",
        "ASP.NET Core",
        "REST APIs"
    };

    private List<string> databaseSkills = new()
    {
        "SQL Server",
        "Entity Framework"
    };
}
